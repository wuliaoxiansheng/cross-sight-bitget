# Shared
NODE_ENV=development

# API
PORT=4000
DATABASE_URL=postgresql://cross_sight:cross_sight@localhost:5432/cross_sight?schema=public
BITGET_BASE_URL=https://api.bitget.com
CORS_ORIGIN=http://localhost:3000
DEFAULT_NOTIONAL_USD=5000
OPEN_EDGE_THRESHOLD=0.003
FUNDING_PERIODS_TO_PRICE=1
# Optional: protect heavy manual endpoints (refresh/live-all/preview).
# Leave empty for open local dev; set a secret to require an x-api-token header.
API_TOKEN=
# Min spacing (ms) between on-demand full scans triggered over HTTP.
LIVE_SCAN_MIN_INTERVAL_MS=10000
# Optional: Feishu bot webhook. Leave empty to disable OPEN opportunity alerts.
FEISHU_WEBHOOK_URL=
# Custom keyword included in every Feishu alert.
FEISHU_KEYWORD=美股
# Per-pair cooldown (ms) to avoid repeating the same OPEN alert every scan.
FEISHU_NOTIFY_COOLDOWN_MS=1800000
# Max OPEN opportunities included in one Feishu message.
FEISHU_NOTIFY_MAX_ITEMS=5
# Reject books when best bid/ask diverges from exchange ticker by more than this fraction.
ORDER_BOOK_TICKER_MAX_DEVIATION=0.02

# Web
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
